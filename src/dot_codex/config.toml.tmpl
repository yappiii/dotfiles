{{- $dst := joinPath .chezmoi.homeDir ".codex" "config.toml" -}}
{{- $existing := dict -}}
{{- if (stat $dst) -}}
  {{- $existing = (include $dst | fromToml) -}}
{{- end -}}
{{- $model := (get $existing "model" | default "gpt-5.5") -}}
{{- $modelReasoningEffort := (get $existing "model_reasoning_effort" | default "medium") -}}
{{- $networkAccess := (get $existing "network_access" | default true) -}}
{{- $features := (get $existing "features" | default (dict)) -}}
{{- $mcpServers := (get $existing "mcp_servers" | default (dict)) -}}
{{- $projects := (get $existing "projects" | default (dict)) -}}
{{- $plugins := (get $existing "plugins" | default (dict)) -}}
{{- $sandboxMode := (get $existing "sandbox_mode" | default "workspace-write") -}}
{{- $sandboxWorkspaceWrite := (get $existing "sandbox_workspace_write" | default (dict)) -}}
{{- $networkAccess := (get $sandboxWorkspaceWrite "network_access" | default (get $existing "network_access" | default true)) -}}

approval_policy = "never"
sandbox_mode = "workspace-write"
model = {{ $model | toJson }}
model_reasoning_effort = {{ $modelReasoningEffort | toJson }}
network_access = {{ $networkAccess | toJson }}

[features]
experimental_use_rmcp_client = true
{{- range $k, $v := $features }}
{{- if and (ne $k "web_search_request") (ne $k "experimental_use_rmcp_client") }}
{{ $k }} = {{ $v | toJson }}
{{- end }}
{{- end }}

[mcp_servers.github]
url = "https://api.githubcopilot.com/mcp"
bearer_token_env_var = "GITHUB_TOKEN"
http_headers = { "X-MCP-Lockdown" = "true" }

[mcp_servers.linear]
url = "https://mcp.linear.app/mcp"

[mcp_servers.notion]
url = "https://mcp.notion.com/mcp"

{{- range $name, $cfg := $mcpServers }}
{{- if and (ne $name "github") (ne $name "linear") (ne $name "notion") }}
[mcp_servers.{{ $name | toJson }}]
{{- range $k, $v := $cfg }}
{{- if not (kindIs "map" $v) }}
{{ $k | toJson }} = {{ $v | toJson }}
{{- end }}
{{- end }}

{{- range $k, $v := $cfg }}
{{- if kindIs "map" $v }}
[mcp_servers.{{ $name | toJson }}.{{ $k | toJson }}]
{{- range $kk, $vv := $v }}
{{ $kk | toJson }} = {{ $vv | toJson }}
{{- end }}

{{- end }}
{{- end }}
{{- end }}
{{- end }}

{{- range $name, $cfg := $plugins }}
[plugins.{{ printf "%q" $name }}]
{{- range $k, $v := $cfg }}
{{ $k }} = {{ $v | toJson }}
{{- end }}

{{- end }}

{{- range $path, $cfg := $projects }}
[projects.{{ printf "%q" $path }}]
{{- range $k, $v := $cfg }}
{{ $k }} = {{ $v | toJson }}
{{- end }}

{{- end }}
